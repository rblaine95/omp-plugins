{
  "name": "@rblaine95/omp-plugins",
  "version": "1.0.0",
  "private": true,
  "description": "rblaine95 personal oh-my-pi extensions, installable via `omp plugin install`.",
  "workspaces": [
    "extensions/*"
  ],
  "scripts": {
    "check": "biome check",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@oh-my-pi/pi-coding-agent": "^16.2.7",
    "@types/bun": "1.3.14",
    "@types/node": "^24.13.2",
    "sort-package-json": "^4.0.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "omp": {
    "extensions": [
      "./extensions/rules-guard/index.ts"
    ]
  }
}
