{
  "name": "@rblaine95/omp-plugins",
  "version": "1.0.0",
  "private": true,
  "description": "rblaine95 personal oh-my-pi extensions, installable via `omp plugin install`.",
  "license": "MIT",
  "workspaces": [
    "extensions/*"
  ],
  "scripts": {
    "check": "biome check",
    "clean": "rm -rf node_modules",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@oh-my-pi/pi-coding-agent": "^16.5.0",
    "@types/bun": "1.3.14",
    "@types/node": "^24.13.3",
    "sort-package-json": "^4.0.0",
    "typescript": "^7.0.2"
  },
  "packageManager": "bun@1.3.14",
  "omp": {
    "extensions": [
      "./extensions/rules-guard/index.ts"
    ]
  }
}
